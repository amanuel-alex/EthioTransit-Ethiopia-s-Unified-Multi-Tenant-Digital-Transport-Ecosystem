# Server
PORT=4000
NODE_ENV=development

# PostgreSQL (Prisma)
# 1) Create the DB once (psql or pgAdmin): CREATE DATABASE ethiotransit;
# 2) Set USER and PASSWORD to match your local Postgres (default superuser is often "postgres").
# 3) Set DATABASE_URL below to YOUR Postgres user/password (must match pgAdmin registration).
#    Migrations load apps/api/.env first; if DATABASE_URL is unset, this file is used (same as API dev).
# 4) Apply migrations (creates tables): pnpm --filter @ethiotransit/api db:migrate:deploy
# 5) Optional seed: pnpm --filter @ethiotransit/api db:seed  (or db:setup = migrate + seed)
DATABASE_URL=postgresql://postgres:2123@localhost:5432/ethiotransit?schema=public

# JWT — use long random strings in production (min 32 chars)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters-long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS — required when NODE_ENV=production (comma-separated origins)
# CORS_ORIGIN=http://localhost:3000

# Seat locks before payment completes
SEAT_LOCK_TTL_MINUTES=15

# Phone login: never set AUTH_DEV_BYPASS in production (enforced at startup).
AUTH_DEV_BYPASS=true
AUTH_DEV_CODE=123456

# Skip real M-Pesa/Chapa calls: mark booking PAID immediately (localhost / CI only; blocked when NODE_ENV=production).
PAYMENTS_MOCK=true

# --- Production webhooks (at least one M-Pesa mechanism required when NODE_ENV=production) ---
# Shared secret your edge proxy sends as header X-EthioTransit-Mpesa-Webhook-Secret when forwarding Daraja callbacks.
# MPESA_WEBHOOK_SECRET=
# Comma-separated caller IPs (or suffix match) allowed to hit the webhook without the secret (use trust proxy behind LB).
# MPESA_WEBHOOK_IP_ALLOWLIST=
# Bypass all webhook hard checks (LOCAL TESTING ONLY — never on the public internet).
# WEBHOOK_INSECURE_ALLOW=false

# M-Pesa Daraja — callback URL must be POST .../api/v1/payments/webhook
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CALLBACK_URL=http://localhost:4000/api/v1/payments/webhook

# Chapa — production requires CHAPA_WEBHOOK_SECRET for HMAC unless CHAPA_WEBHOOKS_DISABLED=true
CHAPA_SECRET_KEY=
CHAPA_PUBLIC_KEY=
CHAPA_BASE_URL=https://api.chapa.co/v1
CHAPA_CALLBACK_URL=http://localhost:4000/api/v1/payments/webhook
CHAPA_RETURN_URL=http://localhost:3000/pay/return
CHAPA_WEBHOOK_SECRET=
# CHAPA_WEBHOOKS_DISABLED=true
